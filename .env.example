# 環境變量配置示例
# 複製此文件為 .env 並根據需要修改值

# 應用配置
APP_NAME=FastAPI 示例應用
APP_VERSION=1.0.0
DEBUG=True

# 服務器配置
HOST=0.0.0.0
PORT=8000

# 數據庫配置（如果使用數據庫）
# DATABASE_URL=sqlite:///./app.db
# DATABASE_URL=postgresql://user:password@localhost/dbname

# JWT 配置（如果實現認證）
# SECRET_KEY=your-secret-key-here
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS 配置
ALLOWED_ORIGINS=*
ALLOWED_METHODS=*
ALLOWED_HEADERS=*
